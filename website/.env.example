# ─────────────────────────────────────────────────────────────
# KillNode Website — environment variables
# Copy to .env (local) or add to Vercel project settings.
# ─────────────────────────────────────────────────────────────

# ── Database (PostgreSQL / Neon) ──────────────────────────────
# Production / Vercel: use the pooled connection string from Neon dashboard.
# Local dev: use a local Postgres connection or a Neon dev-branch URL.
#
# Neon provides two URLs per project:
#   DATABASE_URL  = pooled (pgBouncer)  — used by the Next.js app at runtime
#   DIRECT_URL    = direct connection   — used by Prisma migrations (migrate deploy)
#
# Neon format:
#   postgresql://[user]:[password]@[host].neon.tech/[dbname]?sslmode=require
#
# Local Docker Postgres (optional):
#   DATABASE_URL="postgresql://postgres:postgres@localhost:5432/killnode"
#   DIRECT_URL="postgresql://postgres:postgres@localhost:5432/killnode"
#
DATABASE_URL="postgresql://USER:PASSWORD@HOST.neon.tech/killnode?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST-direct.neon.tech/killnode?sslmode=require"

# ── Admin session ─────────────────────────────────────────────
# ADMIN_SESSION_SECRET must be ≥16 chars. Use `openssl rand -hex 32` in prod.
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="killnode2026"
ADMIN_SESSION_SECRET="change-me-minimum-sixteen-chars"

# ── GitHub Releases API (landing download matrix) ─────────────
GITHUB_REPO_OWNER="Alaustrup"
GITHUB_REPO_NAME="killnode"
# Optional: avoids 60 req/hr unauthenticated limit
GITHUB_TOKEN=""
