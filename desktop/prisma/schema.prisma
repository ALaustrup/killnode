generator client {
  provider = "prisma-client-js"
  output   = "../src/main/generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Setting {
  key   String @id
  value String
}

model TorrentJob {
  infoHash  String   @id
  magnetUri String
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
